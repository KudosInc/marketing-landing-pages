    <title>YYZ People &amp; Culture Council</title>
    <meta
      name="description"
      content="Kudos® is the recognition and rewards platform designed to fit your unique workplace culture."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <style>
      .navbar .container {
        align-items: flex-end;
      }

      #top-form.form-card {
        min-height: 543px;
      }

      .logos-section {
        background-color: #fff;
      }

      .logos-row .logo-item img,
      .logos-row .logo-item svg {
        filter: grayscale(100%);
        opacity: 0.65;
        transition: filter 0.3s, opacity 0.3s;
      }

      .logos-row .logo-item {
        box-sizing: border-box;
      }

      .logos-row .logo-item img {
        width: var(--logo-width, 100%);
        margin: 0 auto;
      }

      .logos-row .logo-item svg {
        width: var(--logo-width, 100%);
        height: auto;
        max-height: 48px;
        margin: 0 auto;
        color: #333;
      }

      .logos-row .logo-item-mnp {
        --logo-width: 92%;
      }

      .logos-row .logo-item-atco {
        --logo-width: 90%;
      }

      .logos-row .logo-item-neo {
        --logo-width: 84%;
      }

      .logos-row .logo-item-nbc {
        --logo-width: 88%;
      }

      .logos-row .logo-item-pcl {
        --logo-width: 100%;
        width: 129px;
      }

      .logos-row .logo-item-pcl img {
        max-height: 59px;
      }

      .logos-row .logo-item-jobber {
        --logo-width: 94%;
      }

      .logos-row .logo-item svg path {
        fill: currentColor;
      }

      .logos-row .logo-item:hover img,
      .logos-row .logo-item:hover svg {
        filter: grayscale(100%);
        opacity: 0.9;
      }

      .hero-list-label,
      .hero-list {
        font-size: 1.15em;
      }

      .hero-content {
        top: 0;
        max-width: 720px;
        padding-right: 0;
      }

      .hero-title {
        margin-bottom: 0.24em;
      }

      .hero-subtitle {
        max-width: 42ch;
        margin-top: 0;
        margin-bottom: 26px;
        color: rgba(247, 249, 251, 0.92);
        font-size: 1.15em;
        font-weight: 500;
        line-height: 1.65;
      }

      .hero-list-label {
        margin-bottom: 12px;
      }

      .hero-list {
        max-width: 30ch;
      }

      .hero-list li {
        font-size: 1em;
        margin-bottom: 10px;
      }

      .hero-pricing-note {
        font-size: 1.08em;
      }

      .yyz-hero-topic {
        max-width: 40ch;
        color: rgba(242, 240, 234, 0.95);
        font-family: 'Figtree', sans-serif;
        font-size: 1.34rem;
        font-weight: 600;
        line-height: 1.45;
        margin: 0 0 28px;
      }

      .yyz-hero-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: stretch;
        gap: 12px;
        max-width: 760px;
        margin: 0 0 20px;
      }

      .yyz-hero-meta-item {
        width: min(100%, 14.25rem);
        max-width: 100%;
        min-width: 0;
        padding: 12px 16px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(8px);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease,
          box-shadow 180ms ease;
      }

      .yyz-hero-meta-item:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.28);
        background: rgba(255, 255, 255, 0.11);
        box-shadow: 0 12px 24px rgba(8, 12, 18, 0.16);
      }

      .yyz-hero-meta-label {
        display: block;
        margin-bottom: 4px;
        color: rgba(242, 240, 234, 0.76);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .yyz-hero-meta-value {
        margin: 0;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.5;
      }

      .yyz-hero-meta-value a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #fff;
        line-height: inherit;
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.35);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.14em;
      }

      .yyz-hero-meta-value a:hover {
        color: #fff;
        text-decoration-color: currentColor;
      }

      .yyz-hero-link-icon {
        width: 0.92em;
        height: 0.92em;
        flex-shrink: 0;
        color: #ff8b74;
      }

      .yyz-visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (prefers-reduced-motion: reduce) {
        .yyz-hero-meta-item {
          transition: none;
        }

        .yyz-hero-meta-item:hover {
          transform: none;
          box-shadow: none;
        }
      }

      .yyz-navbar-brand img {
        height: 73px;
        width: auto;
        transform: translateY(8px);
      }

      .yyz-sponsor {
        position: relative;
        display: flex;
        align-items: flex-end;
        align-self: center;
      }

      .yyz-sponsor-label {
        position: absolute;
        bottom: 100%;
        left: 0;
        margin-bottom: 4px;
        color: #fff;
        font-size: 0.64rem;
        font-style: italic;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .yyz-sponsor-logo img {
        height: 36px;
        width: auto;
      }

      @media (max-width: 767px) {
        .yyz-navbar-brand img {
          height: 60px;
          transform: translateY(6px);
        }

        .yyz-sponsor-logo img {
          height: 30px;
        }

        .yyz-sponsor-label {
          font-size: 0.58rem;
        }

        .yyz-hero-topic {
          font-size: 1.18rem;
        }

        .yyz-hero-meta {
          flex-direction: column;
          gap: 10px;
        }

        .yyz-hero-meta-item {
          width: 100%;
          min-width: 0;
        }

      }
    </style>
  </head>
