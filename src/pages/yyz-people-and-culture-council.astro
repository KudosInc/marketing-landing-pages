    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">YYZ People &amp; Culture Council</h1>
        <p class="yyz-hero-topic">AI in the Workplace: Challenges &amp; Learnings from Toronto HR Leaders</p>
        <div class="yyz-hero-meta" aria-label="Event details">
          <div class="yyz-hero-meta-item">
            <span class="yyz-hero-meta-label">When</span>
            <p class="yyz-hero-meta-value">June 3, 6-8 PM</p>
          </div>
          <div class="yyz-hero-meta-item">
            <span class="yyz-hero-meta-label">Where</span>
            <p class="yyz-hero-meta-value">
              <a
                href="https://www.google.com/maps/place/LOCAL+Public+Eatery+Adelaide/@43.6489964,-79.3850019,18.18z/data=!4m6!3m5!1s0x882b35f03cbbb9e9:0xc324e1026e82dc46!8m2!3d43.6489576!4d-79.3843408!16s%2Fg%2F11lcr945zl?entry=ttu&g_ep=EgoyMDI2MDQxNS4wIKXMDSoASAFQAw%3D%3D"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LOCAL Public Eatery, opens in a new tab"
              >
                LOCAL Public Eatery
