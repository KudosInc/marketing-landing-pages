---
import '../styles/global.css';

const currentYear = new Date().getFullYear();
const legalLinks = {
  trademarks: 'https://www.kudos.com/trademarks',
  terms: 'https://www.kudos.com/terms-of-service',
  privacy: 'https://www.kudos.com/privacy-policy',
  cookies: 'https://www.kudos.com/privacy-policy',
  status: 'https://status.kudos.com/',
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
